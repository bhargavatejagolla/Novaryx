{
    "name": "novaryx-web",
    "version": "2.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3000",
        "build": "next build",
        "start": "next start -p 3000",
        "backend:start": "cd .. && python -c \"from system.realtime.websocket_server import WebSocketServer; s = WebSocketServer(); s.start(); print('WebSocket running on ws://localhost:9001'); import time; time.sleep(999999)\"",
        "backend:test": "cd .. && python novaryx_e2e.py --test",
        "dev:full": "concurrently \"npm run dev\" \"npm run backend:start\"",
        "lint": "next lint"
    },
    "dependencies": {
        "clsx": "2.1.1",
        "concurrently": "^8.2.2",
        "framer-motion": "11.1.7",
        "lucide-react": "0.378.0",
        "next": "^14.2.15",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@types/node": "20.12.12",
        "@types/react": "18.3.2",
        "@types/react-dom": "18.3.0",
        "autoprefixer": "10.4.19",
        "postcss": "8.4.38",
        "tailwindcss": "3.4.3",
        "typescript": "5.4.5"
    }
}
